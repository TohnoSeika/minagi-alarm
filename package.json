{
  "name": "minagi-alarm-tauri",
  "version": "1.4.0",
  "description": "⏰ Minagi Alarm — 桃华帮 Minagi 做的精致桌面闹钟（Tauri 版）",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "dist": "npm run tauri:build && powershell -Command \"Copy-Item 'src-tauri/target/release/bundle/nsis/Minagi Alarm_*-setup.exe' 'dist/' -Force\"",
    "dist:pack": "powershell -ExecutionPolicy Bypass -File scripts/build-installer.ps1"
  },
  "dependencies": {
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@fontsource/quicksand": "^5.2.10",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-autostart": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-notification": "^2",
    "i18next": "^26.3.6",
    "react-i18next": "^17.0.9"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.3.3",
    "vite": "^5"
  }
}
